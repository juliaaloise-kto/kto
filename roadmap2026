                { title: "Automatic static code analysis on all pipelines", start: 6, end: 12, deadline: "Q4 2026 & Q1 2027", description: "Catch code smells, vulnerabilities, and style violations at commit time — not in production." },
                { title: "UBOS – Modernized and modularized architecture", start: wcStart, end: 9, deadline: "Q3 2026 & Q4 2026", description: "Decompose a monolithic frontend into maintainable modules." },
                { title: "Observability: Coralogix – Phase 2", start: 6, end: 9, deadline: "Q3 & Q4 2026", description: "Extend coverage beyond the happy path. Catch edge cases and secondary flows." },
                { title: "Wallet Service (with Shared DB)", start: wcStart, end: 6, deadline: "Q3 2026", description: "Build a dedicated wallet service to centralize balance management." }
            ]},
            { domain: "Design System", items: [
                { title: "Phase 1 - Figma Integration", start: 0, end: preWCDeadline, deadline: "Q2 2026", description: "Establish a single source of truth between design and code." },
                { title: "Phase 2 - Implement Components", start: wcStart, end: 12, deadline: "Q3 2026 to Q1 2027", description: "Expand the component library so product teams can build faster." },
                { title: "FE Refactor", start: 0, end: 12, deadline: "Q2 2026 to Q1 2027", description: "Rewrite old JS/Gatsby code in modularized TypeScript with unit testing." },
                { title: "CodeMagic PoC", start: 1, end: 6, deadline: "Q2 & Q3 2026", description: "Evaluate a CI/CD platform built for mobile." },
                { title: "Unit Testing adoption", start: 1, end: 6, deadline: "Q2 & Q3 2026", description: "Establish a testing culture in the app codebase." },
                { title: "Further nativization", start: wcStart, end: 9, deadline: "Q3 & Q4 2026", description: "Replace webviews with native screens progressively." }
            ]}
        ];

        const domainColors = {
            "Sportsbook": { fill: "rgba(59, 130, 246, 0.18)", accent: "#3b82f6", text: "#1e40af" },
            "Casino": { fill: "rgba(99, 102, 241, 0.18)", accent: "#6366f1", text: "#3730a3" },
            "Registration & Early Life": { fill: "rgba(20, 184, 166, 0.18)", accent: "#14b8a6", text: "#0f766e" },
            "Payments": { fill: "rgba(100, 116, 139, 0.18)", accent: "#64748b", text: "#334155" },
            "Loyalty": { fill: "rgba(244, 63, 94, 0.18)", accent: "#f43f5e", text: "#9f1239" },
            "Mobile App": { fill: "rgba(139, 92, 246, 0.18)", accent: "#8b5cf6", text: "#5b21b6" },
            "Platform": { fill: "rgba(249, 115, 22, 0.18)", accent: "#f97316", text: "#9a3412" },
            "Design System": { fill: "rgba(6, 182, 212, 0.18)", accent: "#06b8d4", text: "#0e7490" }
        };

        const domainIcons = {
            "Sportsbook": `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>`,
            "Casino": `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><path d="M7 7h.01"/><path d="M17 7h.01"/><path d="M7 17h.01"/><path d="M17 17h.01"/><path d="M12 12h.01"/></svg>`,
            "Registration & Early Life": `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" x2="19" y1="8" y2="14"/><line x1="16" x2="22" y1="11" y2="11"/></svg>`,
            "Payments": `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>`,
            "Loyalty": `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
            "Mobile App": `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>`,
            "Platform": `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>`,
            "Design System": `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19 7-7 3 3-7 7-3-3Z"/><path d="m18 13-1.5-7.5L2 2l3.5 14.5L13 18l5-5Z"/><path d="m2 2 7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>`
        };

        let selectedDomains = new Set(roadmapData.map(d => d.domain));

        function renderFilters() {
            const container = document.getElementById('filter-container');
            container.innerHTML = '';
            roadmapData.forEach(group => {
                const isActive = selectedDomains.has(group.domain);
                const btn = document.createElement('button');
                const cfg = domainColors[group.domain];
                
                btn.className = `flex items-center gap-2.5 px-4 py-2 rounded-2xl text-[10px] font-bold tracking-tight liquid-glass-bubble border transition-all ${isActive ? 'active' : 'opacity-60 grayscale-[40%]'}`;
                
                const dot = document.createElement('span');
                dot.style.backgroundColor = cfg.accent;
                dot.className = `w-2 h-2 rounded-full shadow-[0_0_8px_rgba(0,0,0,0.1)]`;
                
                const label = document.createElement('span');
                label.textContent = group.domain.toUpperCase();
                
                btn.appendChild(dot);
                btn.appendChild(label);
                
                btn.onclick = () => {
                    if (selectedDomains.has(group.domain)) {
                        if (selectedDomains.size > 1) selectedDomains.delete(group.domain);
                    } else {
                        selectedDomains.add(group.domain);
                    }
                    renderFilters();
                    renderGantt();
                };
                container.appendChild(btn);
            });
        }

        function renderGantt() {
            const container = document.getElementById('gantt-content');
            container.innerHTML = '';

            roadmapData.forEach(group => {
                if (!selectedDomains.has(group.domain)) return;

                const swimlaneHeader = document.createElement('div');
                swimlaneHeader.className = "swimlane-header glass py-2 px-6 sticky top-0 z-10 border-b border-slate-200/50 flex items-center gap-2.5";
                
                const iconContainer = document.createElement('span');
                iconContainer.className = "text-slate-400";
                iconContainer.innerHTML = domainIcons[group.domain] || '';
                
                const titleText = document.createElement('span');
                titleText.className = "text-[10px] font-bold uppercase tracking-[0.15em] text-slate-500";
                titleText.textContent = group.domain;
                
                swimlaneHeader.appendChild(iconContainer);
                swimlaneHeader.appendChild(titleText);
                container.appendChild(swimlaneHeader);

                group.items.forEach(item => {
                    const row = document.createElement('div');
                    row.className = "flex border-b border-slate-100 hover:bg-slate-50/50 transition-colors group cursor-pointer h-10";
                    row.onclick = () => openDrawer(item, group.domain);

                    const width = ((item.end - item.start) / 12) * 100;
                    const left = (item.start / 12) * 100;
                    const cfg = domainColors[group.domain];

                    row.innerHTML = `
                        <div class="flex-grow relative px-4">
                            <div class="absolute h-6 rounded-lg gantt-bar flex items-center px-3" 
                                 style="left: ${left}%; width: ${width}%; top: 50%; transform: translateY(-50%); background-color: ${cfg.fill}; border-left: 3px solid ${cfg.accent};">
                                 <span class="text-[10px] font-medium truncate" style="color: ${cfg.text}">${item.title}</span>
                            </div>
                        </div>
                    `;
                    container.appendChild(row);
                });
            });
        }

        function openDrawer(item, domainName) {
            const drawer = document.getElementById('drawer');
            const overlay = document.getElementById('drawer-overlay');
            const cfg = domainColors[domainName];
            
            document.getElementById('drawer-title').textContent = item.title;
            const domainEl = document.getElementById('drawer-domain');
            domainEl.textContent = domainName;
            domainEl.style.color = cfg.accent;
            
            document.getElementById('deadline-text').textContent = item.deadline;
            document.getElementById('drawer-description').textContent = item.description;

            overlay.classList.remove('hidden');
            drawer.classList.add('is-visible');
        }

        function closeDrawer() {
            document.getElementById('drawer').classList.remove('is-visible');
            document.getElementById('drawer-overlay').classList.add('hidden');
        }

        document.getElementById('close-drawer').onclick = closeDrawer;
        document.getElementById('drawer-overlay').onclick = closeDrawer;

        renderFilters();
        renderGantt();
    </script>
</body>
</html>
